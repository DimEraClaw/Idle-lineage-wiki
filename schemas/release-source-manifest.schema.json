{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dim-era-claw.github.io/idle-lineage-wiki/schemas/release-source-manifest.schema.json",
  "title": "Release Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceRepository",
    "branch",
    "commitSha",
    "commitDate",
    "gameVersion",
    "retrievedAt",
    "retrievalMethod",
    "files",
    "manifestSchemaVersion"
  ],
  "properties": {
    "sourceRepository": {
      "type": "string",
      "pattern": "^https://[^/?#]+/[^/?#]+/[^/?#]+(?:\\.git)?$"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\s~^:?*\\[\\]\\\\]+(?:/[^\\s~^:?*\\[\\]\\\\]+)*$"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "commitDate": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "gameVersion": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "retrievedAt": {
      "type": "string",
      "format": "date-time"
    },
    "retrievalMethod": {
      "enum": ["git_archive", "git_checkout", "github_raw", "github_pages"]
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceFile" }
    },
    "manifestSchemaVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    }
  },
  "$defs": {
    "sourceFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[^\\u0000]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
